  </div>

  <div class="history" id="historyPanel">
    <div class="history-label">Recently added</div>
    <div id="historyList"></div>
  </div>

  <div class="footer">◈ powered by CrossRef &amp; Anthropic</div>
</div>

<script>
  const COLLECTION_ID = "a6d35521-c29d-23e9-e19a-cc5cdf331299";
  const CRAFT_MCP_URL = "https://mcp.craft.do/my/mcp";
  const STATUS_OPTIONS = ["To Read", "Reading", "Done", "Cited"];
  const TAG_OPTIONS = ["ML", "NLP", "CV", "Biology", "Medicine", "Physics", "Review"];

  let meta = null;
  let selectedStatus = "To Read";
  let selectedTags = [];
  let history = [];

  // Build status buttons
  const statusEl = document.getElementById('statusOptions');
  STATUS_OPTIONS.forEach(s => {
    const b = document.createElement('button');
    b.className = 'opt-btn' + (s === selectedStatus ? ' active' : '');
    b.textContent = s;
    b.onclick = () => {
      selectedStatus = s;
      statusEl.querySelectorAll('.opt-btn').forEach(x => x.classList.remove('active'));
      b.classList.add('active');
    };
    statusEl.appendChild(b);
  });

  // Build tag buttons
  const tagEl = document.getElementById('tagOptions');
  TAG_OPTIONS.forEach(t => {
    const b = document.createElement('button');
    b.className = 'opt-btn';
    b.textContent = t;
    b.onclick = () => {
      if (selectedTags.includes(t)) {
        selectedTags = selectedTags.filter(x => x !== t);
        b.classList.remove('tag-active');
      } else {
        selectedTags.push(t);
        b.classList.add('tag-active');
      }
    };
    tagEl.appendChild(b);
  });

  function showError(msg) {
    const el = document.getElementById('errorMsg');
    el.textContent = '⚠ ' + msg;
    el.classList.add('show');
  }
  function clearError() {
    document.getElementById('errorMsg').classList.remove('show');
  }
  function showSuccess() {
    const el = document.getElementById('successMsg');
    el.classList.add('show');
    setTimeout(() => el.classList.remove('show'), 2500);
  }

  async function handleFetch() {
    const raw = document.getElementById('doiInput').value.trim();
    if (!raw) return;
    clearError();
    document.getElementById('preview').classList.remove('show');

    const fetchBtn = document.getElementById('fetchBtn');
    fetchBtn.disabled = true;
    fetchBtn.innerHTML = '<span class="spinner"></span>';

    try {
      const doi = raw.replace(/^https?:\/\/doi\.org\//i, '').trim();
      const res = await fetch(`https://api.crossref.org/works/${encodeURIComponent(doi)}`);
      if (!res.ok) throw new Error("DOI not found — please check and try again.");
      const data = await res.json();
      const w = data.message;

      const authors = (w.author || [])
        .map(a => [a.family, a.given].filter(Boolean).join(', '))
        .join('; ') || 'Unknown';

      const journal = w['container-title']?.[0] || w['short-container-title']?.[0] || w.publisher || 'Unknown';
      const year = w.published?.['date-parts']?.[0]?.[0]
        || w['published-print']?.['date-parts']?.[0]?.[0]
        || w['published-online']?.['date-parts']?.[0]?.[0]
        || null;
      const title = w.title?.[0] || 'Untitled';
      const abstract = w.abstract ? w.abstract.replace(/<[^>]+>/g, '').trim() : '';
      const url = w.URL || `https://doi.org/${doi}`;

      meta = { title, authors, journal, year, abstract, url, doi };

      // Populate preview
      document.getElementById('prevTitle').textContent = title;
      const shortAuthors = authors.split(';').slice(0, 3).join(';') + (authors.split(';').length > 3 ? ' et al.' : '');
      document.getElementById('prevAuthors').textContent = shortAuthors;

      const chips = document.getElementById('prevChips');
      chips.innerHTML = '';
      [journal, year ? String(year) : null, doi].filter(Boolean).forEach((c, i) => {
        const span = document.createElement('span');
        span.className = 'chip' + (i === 2 ? ' muted' : '');
        span.textContent = c;
        chips.appendChild(span);
      });

      const absEl = document.getElementById('prevAbstract');
      if (abstract) {
        absEl.textContent = abstract.slice(0, 280) + (abstract.length > 280 ? '…' : '');
        absEl.style.display = 'block';
      } else {
        absEl.style.display = 'none';
      }

      document.getElementById('preview').classList.add('show');
      document.getElementById('clearBtn').style.display = 'block';
      fetchBtn.style.display = 'none';

    } catch (e) {
      showError(e.message);
      fetchBtn.disabled = false;
      fetchBtn.innerHTML = 'Fetch';
    }
  }

  function handleClear() {
    meta = null;
    selectedTags = [];
    selectedStatus = 'To Read';
    document.getElementById('doiInput').value = '';
    document.getElementById('preview').classList.remove('show');
    document.getElementById('clearBtn').style.display = 'none';
    document.getElementById('fetchBtn').style.display = 'block';
    document.getElementById('fetchBtn').disabled = false;
    document.getElementById('fetchBtn').textContent = 'Fetch';
    document.getElementById('notesInput').value = '';
    tagEl.querySelectorAll('.opt-btn').forEach(b => b.classList.remove('tag-active'));
    statusEl.querySelectorAll('.opt-btn').forEach((b, i) => {
      b.classList.toggle('active', STATUS_OPTIONS[i] === 'To Read');
    });
    clearError();
  }

  async function handleAdd() {
    if (!meta) return;
    const addBtn = document.getElementById('addBtn');
    addBtn.disabled = true;
    addBtn.innerHTML = '<span class="spinner"></span> Adding to Craft…';
    clearError();

    const notes = document.getElementById('notesInput').value;

    try {
      const response = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 1000,
          mcp_servers: [{ type: "url", url: CRAFT_MCP_URL, name: "craft" }],
          messages: [{
            role: "user",
            content: `Add a row to Craft collection ID "${COLLECTION_ID}" with these exact values using the collectionItems_add tool:
- title: ${JSON.stringify(meta.title)}
- doi: ${JSON.stringify(meta.doi)}
- authors: ${JSON.stringify(meta.authors)}
- journal: ${JSON.stringify(meta.journal)}
- year: ${meta.year ?? 'null'}
- status: ${JSON.stringify(selectedStatus)}
- tags: ${JSON.stringify(selectedTags)}
- abstract: ${JSON.stringify(meta.abstract)}
- url: ${JSON.stringify(meta.url)}
- notes: ${JSON.stringify(notes)}
Reply only with SUCCESS or FAILED: <reason>.`
          }]
        })
      });

      if (!response.ok) throw new Error("API error " + response.status);
      const data = await response.json();
      const text = (data.content || []).map(b => b.text || '').join('');
      if (text.includes('FAILED')) throw new Error(text.replace('FAILED:', '').trim());

      // Add to history
      history.unshift({ title: meta.title, year: meta.year });
      renderHistory();
      showSuccess();
      handleClear();

    } catch (e) {
      showError(e.message || "Something went wrong. Please try again.");
      addBtn.disabled = false;
      addBtn.innerHTML = 'Add to Craft →';
    }
  }

  function renderHistory() {
    const panel = document.getElementById('historyPanel');
    const list = document.getElementById('historyList');
    if (history.length === 0) { panel.classList.remove('show'); return; }
    panel.classList.add('show');
    list.innerHTML = '';
    history.slice(0, 6).forEach(h => {
      const row = document.createElement('div');
      row.className = 'history-item';
      row.innerHTML = `<span class="history-name">${h.title}</span><span class="history-year">${h.year || '—'}</span>`;
      list.appendChild(row);
    });
  }

  // Enter key on input
  document.getElementById('doiInput').addEventListener('keydown', e => {
    if (e.key === 'Enter') handleFetch();
  });
</script>

</body>
</html>

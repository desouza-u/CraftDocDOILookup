<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Research Paper Tracker — DOI Adder</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
–bg: #080d14;
–surface: #0d1520;
–surface2: #111e2e;
–border: #1a2b3f;
–border2: #243650;
–text: #dce8f5;
–text2: #7a9abf;
–text3: #3d5a7a;
–accent: #4a8fff;
–accent2: #2d6bcc;
–success: #3dd68c;
–error: #f87171;
–tag-bg: #0f1e30;
}

body {
background: var(–bg);
color: var(–text);
font-family: ‘DM Sans’, sans-serif;
min-height: 100vh;
display: flex;
flex-direction: column;
align-items: center;
padding: 40px 16px 80px;
}

/* Ambient background */
body::before {
content: ‘’;
position: fixed;
top: -200px; left: 50%;
transform: translateX(-50%);
width: 800px; height: 500px;
background: radial-gradient(ellipse, rgba(74,143,255,0.07) 0%, transparent 70%);
pointer-events: none;
z-index: 0;
}

.wrap {
position: relative;
z-index: 1;
width: 100%;
max-width: 560px;
}

/* Header */
.header {
text-align: center;
margin-bottom: 36px;
}
.header-eyebrow {
font-family: ‘DM Mono’, monospace;
font-size: 11px;
letter-spacing: 0.18em;
text-transform: uppercase;
color: var(–accent);
margin-bottom: 10px;
}
.header h1 {
font-family: ‘DM Serif Display’, serif;
font-size: 34px;
font-weight: 400;
color: var(–text);
letter-spacing: -0.5px;
line-height: 1.1;
}
.header h1 em {
font-style: italic;
color: var(–accent);
}
.header-sub {
margin-top: 10px;
font-size: 14px;
color: var(–text3);
}

/* Card */
.card {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 18px;
padding: 28px;
box-shadow: 0 32px 80px rgba(0,0,0,0.5), 0 0 0 1px rgba(74,143,255,0.04);
}

/* DOI Input */
.input-group {
display: flex;
gap: 8px;
margin-bottom: 16px;
}
.doi-input {
flex: 1;
background: var(–surface2);
border: 1px solid var(–border);
border-radius: 12px;
padding: 13px 16px;
font-family: ‘DM Mono’, monospace;
font-size: 13px;
color: var(–text);
outline: none;
transition: border-color 0.2s;
}
.doi-input:focus { border-color: var(–accent2); }
.doi-input::placeholder { color: var(–text3); }

.btn-fetch {
background: var(–accent);
color: #fff;
border: none;
border-radius: 12px;
padding: 13px 20px;
font-family: ‘DM Sans’, sans-serif;
font-size: 14px;
font-weight: 600;
cursor: pointer;
white-space: nowrap;
transition: background 0.2s, transform 0.1s;
}
.btn-fetch:hover:not(:disabled) { background: #5a9fff; }
.btn-fetch:active:not(:disabled) { transform: scale(0.97); }
.btn-fetch:disabled { opacity: 0.5; cursor: not-allowed; }

.btn-clear {
background: var(–surface2);
color: var(–text3);
border: 1px solid var(–border);
border-radius: 12px;
padding: 13px 14px;
font-size: 16px;
cursor: pointer;
transition: color 0.2s;
}
.btn-clear:hover { color: var(–text2); }

/* Messages */
.msg {
border-radius: 10px;
padding: 11px 14px;
font-size: 13px;
margin-bottom: 14px;
display: none;
}
.msg.show { display: block; }
.msg.error { background: #1a0f0f; border: 1px solid #3d1a1a; color: var(–error); }
.msg.success {
background: #0a1f14;
border: 1px solid #1a4030;
color: var(–success);
text-align: center;
font-size: 15px;
font-weight: 600;
padding: 14px;
}

/* Spinner */
.spinner {
display: inline-block;
width: 14px; height: 14px;
border: 2px solid rgba(255,255,255,0.25);
border-top-color: #fff;
border-radius: 50%;
animation: spin 0.7s linear infinite;
vertical-align: middle;
margin-right: 4px;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* Preview panel */
.preview {
background: var(–surface2);
border: 1px solid var(–border);
border-radius: 14px;
padding: 20px;
margin-bottom: 16px;
display: none;
animation: fadeUp 0.25s ease;
}
.preview.show { display: block; }
@keyframes fadeUp {
from { opacity: 0; transform: translateY(6px); }
to   { opacity: 1; transform: translateY(0); }
}

.preview-title {
font-family: ‘DM Serif Display’, serif;
font-size: 18px;
font-weight: 400;
color: var(–text);
line-height: 1.35;
margin-bottom: 8px;
}
.preview-authors {
font-size: 13px;
color: var(–text2);
margin-bottom: 10px;
line-height: 1.5;
}
.preview-chips {
display: flex;
flex-wrap: wrap;
gap: 6px;
margin-bottom: 12px;
}
.chip {
font-family: ‘DM Mono’, monospace;
font-size: 11px;
background: var(–tag-bg);
color: var(–accent);
border: 1px solid var(–border2);
border-radius: 20px;
padding: 3px 10px;
}
.chip.muted { color: var(–text3); border-color: var(–border); }
.preview-abstract {
font-size: 13px;
color: var(–text3);
line-height: 1.65;
font-style: italic;
border-left: 2px solid var(–border2);
padding-left: 12px;
margin-bottom: 4px;
}

/* Form fields */
.field { margin-top: 16px; }
.field-label {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
letter-spacing: 0.12em;
text-transform: uppercase;
color: var(–text3);
margin-bottom: 7px;
}
.options {
display: flex;
flex-wrap: wrap;
gap: 6px;
}
.opt-btn {
background: var(–tag-bg);
color: var(–text3);
border: 1px solid var(–border);
border-radius: 8px;
padding: 5px 13px;
font-family: ‘DM Sans’, sans-serif;
font-size: 13px;
cursor: pointer;
transition: all 0.15s;
}
.opt-btn:hover { color: var(–text2); border-color: var(–border2); }
.opt-btn.active {
background: var(–accent);
color: #fff;
border-color: var(–accent);
}
.opt-btn.tag-active {
background: #0d2240;
color: #63b3ff;
border-color: #1a4070;
}

textarea.notes-input {
width: 100%;
background: var(–surface);
border: 1px solid var(–border);
border-radius: 10px;
padding: 10px 13px;
font-family: ‘DM Sans’, sans-serif;
font-size: 13px;
color: var(–text);
resize: vertical;
outline: none;
transition: border-color 0.2s;
margin-top: 2px;
}
textarea.notes-input:focus { border-color: var(–border2); }
textarea.notes-input::placeholder { color: var(–text3); }

.btn-add {
margin-top: 20px;
width: 100%;
background: linear-gradient(135deg, #3a7ef0, #4f5ef7);
color: #fff;
border: none;
border-radius: 12px;
padding: 15px;
font-family: ‘DM Sans’, sans-serif;
font-size: 15px;
font-weight: 600;
cursor: pointer;
letter-spacing: 0.01em;
transition: opacity 0.2s, transform 0.1s;
display: flex;
align-items: center;
justify-content: center;
gap: 6px;
}
.btn-add:hover:not(:disabled) { opacity: 0.9; }
.btn-add:active:not(:disabled) { transform: scale(0.98); }
.btn-add:disabled { opacity: 0.55; cursor: not-allowed; }

/* History */
.history {
margin-top: 28px;
display: none;
}
.history.show { display: block; }
.history-label {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
letter-spacing: 0.12em;
text-transform: uppercase;
color: var(–text3);
margin-bottom: 10px;
}
.history-item {
display: flex;
justify-content: space-between;
align-items: baseline;
padding: 8px 0;
border-bottom: 1px solid var(–border);
gap: 8px;
}
.history-item:last-child { border-bottom: none; }
.history-name {
font-size: 13px;
color: var(–text2);
overflow: hidden;
text-overflow: ellipsis;
white-space: nowrap;
flex: 1;
}
.history-year {
font-family: ‘DM Mono’, monospace;
font-size: 11px;
color: var(–text3);
flex-shrink: 0;
}

/* Footer */
.footer {
margin-top: 24px;
text-align: center;
font-size: 12px;
color: var(–text3);
font-family: ‘DM Mono’, monospace;
}
</style>

</head>
<body>
<div class="wrap">

  <div class="header">
    <div class="header-eyebrow">Research Paper Tracker</div>
    <h1>Add by <em>DOI</em></h1>
    <div class="header-sub">Fetches from CrossRef · Saves to your Craft table</div>
  </div>

  <div class="card">
    <div class="input-group">
      <input class="doi-input" id="doiInput" type="text"
        placeholder="10.1038/nature14539  or  https://doi.org/…"
        autocomplete="off" autocorrect="off" spellcheck="false" />
      <button class="btn-fetch" id="fetchBtn" onclick="handleFetch()">Fetch</button>
      <button class="btn-clear" id="clearBtn" onclick="handleClear()" style="display:none">✕</button>
    </div>

```
<div class="msg error" id="errorMsg"></div>
<div class="msg success" id="successMsg">✓ Added to Craft</div>

<div class="preview" id="preview">
  <div class="preview-title" id="prevTitle"></div>
  <div class="preview-authors" id="prevAuthors"></div>
  <div class="preview-chips" id="prevChips"></div>
  <div class="preview-abstract" id="prevAbstract" style="display:none"></div>

  <div class="field">
    <div class="field-label">Status</div>
    <div class="options" id="statusOptions"></div>
  </div>
  <div class="field">
    <div class="field-label">Tags</div>
    <div class="options" id="tagOptions"></div>
  </div>
  <div class="field">
    <div class="field-label">Notes</div>
    <textarea class="notes-input" id="notesInput" rows="2" placeholder="Your thoughts…"></textarea>
